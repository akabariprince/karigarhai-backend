model Chat {
  id                 String     @id @default(uuid()) @db.Uuid
  hireId             String     @unique @db.Uuid
  user1Id            String @db.Uuid
  user2Id            String @db.Uuid
  lastMessageAt      DateTime?
  lastMessage        String?
  isArchivedUser1    Boolean    @default(false)
  isArchivedUser2    Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  hire               Hire       @relation(fields: [hireId], references: [id], onDelete: Cascade)
  user1              User       @relation(fields: [user1Id], references: [id], onDelete: Cascade)
  user2              User       @relation(fields: [user2Id], references: [id], onDelete: Cascade)
  messages           ChatMessage[]

  @@index([hireId])
  @@index([user1Id])
  @@index([user2Id])
  @@index([lastMessageAt])
}

model ChatMessage {
  id                 String     @id @default(uuid()) @db.Uuid
  chatId             String @db.Uuid
  senderId           String @db.Uuid
  type               MessageType
  text               String?
  mediaUrl           String?
  mediaDuration      Int?
  metadata           String?
  isRead             Boolean    @default(false)
  readAt             DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  chat               Chat       @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender             User       @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
  @@index([isRead])
  @@index([createdAt])
}

enum MessageType {
  TEXT
  IMAGE
  VOICE
  FILE
  SYSTEM
}
